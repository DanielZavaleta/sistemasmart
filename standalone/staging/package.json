{
    "name": "sistema-smart-pos",
    "version": "1.0.0",
    "description": "Sistema Smart POS - Standalone Desktop App",
    "main": "electron/main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "author": "DanielRodZa",
    "license": "ISC",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "electron-packager": "^17.1.2",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "tree-kill": "^1.2.2"
    },
    "build": {
        "appId": "com.sistemasmart.pos",
        "productName": "Sistema Smart POS",
        "files": [
            "electron/**/*",
            "frontend/build/**/*",
            "backend/**/*",
            "!backend/**/__pycache__/**/*",
            "!backend/**/*.sqlite3",
            "!**/*.pyc"
        ],
        "directories": {
            "buildResources": "assets"
        },
        "win": {
            "target": "nsis",
            "forceCodeSigning": false
        }
    }
}
